# ── LLM Provider ────────────────────────────────────────────────────────────
# Groq (recommended — free tier, tool-calling support)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Alternative: OpenRouter (drop-in replacement, wider model selection)
# GROQ_API_BASE=https://openrouter.ai/api/v1
# GROQ_MODEL=openai/gpt-4o-mini

# ── Google Cloud Vision API (Backend 2 — document OCR) ───────────────────────
GOOGLE_CLOUD_VISION_ENABLED=true
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# ── PostgreSQL (Backend 1 — transactions, rules, alerts, customers) ──────────
# For local Docker: use the values already set in docker-compose.yml
# For Supabase: replace with your project connection string
DATABASE_URL=postgresql://aml:aml@localhost:5432/aml
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aml
POSTGRES_USER=aml
POSTGRES_PASSWORD=your_postgres_password_here

# ── Optional Services ─────────────────────────────────────────────────────────
# Reverse image search (SerpAPI)
SERPAPI_API_KEY=
# AI image detection (Sightengine)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
# Imgur (temporary public URL for reverse image search)
IMGUR_CLIENT_ID=

# ── CORS (comma-separated origins; leave * for development) ──────────────────
CORS_ORIGINS=*

# ── Frontend environment (when running outside Docker) ───────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5001/api
NEXT_PUBLIC_API_URL_2=http://localhost:5002/api
